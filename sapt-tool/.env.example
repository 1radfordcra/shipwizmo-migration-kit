# SAPT Tool (Shipping Analysis & Pricing Tool) — Environment Variables
# Copy this file to .env and fill in real values
# Works with: Replit Secrets | Docker .env | Azure App Settings

# Google OAuth 2.0 (from Google Cloud Console → project: buoyant-silicon-345213)
GOOGLE_CLIENT_ID=105648453442-gjnirc4fa4tmii07lt1lmd353serh4ng.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Admin account
ADMIN_EMAIL=craig@shipwizmo.com

# Admin default password (used for first-time setup only; bcrypt-hashed at runtime)
# If not set, a random UUID is generated — check server logs on first boot
ADMIN_DEFAULT_PASSWORD=change-me-on-first-login

# CORS allowed origins (comma-separated)
# Add your production domain when migrating off Perplexity hosting
CORS_ORIGINS=https://www.perplexity.ai,https://sites.pplx.app

# Database (for Azure migration — replace SQLite with Azure SQL)
# DATABASE_URL=postgresql://user:pass@your-azure-sql.database.windows.net:5432/broadreach

# Server config
PORT=8000
HOST=0.0.0.0
