# Broad Reach Command Center — Environment Variables
# Copy this file to .env and fill in real values
# Works with: Replit Secrets | Docker .env | Azure App Settings

# HubSpot (same token as Outbound Machine — Account: 6282372)
HUBSPOT_PAT=pat-na1-your-hubspot-private-app-token

# Google OAuth (same client ID as SAPT Tool + Customs Data Portal)
# Project: buoyant-silicon-345213 | Published to production
# Authorized JS Origins: https://www.perplexity.ai, https://sites.pplx.app
# When migrating to own domain, add that domain to authorized origins in Google Cloud Console
GOOGLE_CLIENT_ID=105648453442-gjnirc4fa4tmii07lt1lmd353serh4ng.apps.googleusercontent.com

# CORS allowed origins (comma-separated)
# Add your production domain when migrating off Perplexity hosting
CORS_ORIGINS=https://www.perplexity.ai,https://sites.pplx.app

# Cache updater script settings (update_dashboard_cache.py, update_cache_fast.py)
DOMAIN=brdrch.com
CACHE_PATH=./dashboard_cache.json
WARMUP_TRACKER_PATH=../outbound-machine/warmup_tracker.json
EXCLUSION_LIST_PATH=../outbound-machine/active_clients_exclusion_list.txt

# If running cache updater as Azure Function:
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
