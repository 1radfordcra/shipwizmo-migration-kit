{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Broad Reach Command Center \u2014 Static Dashboard + FastAPI Proxy",
    "_generator": {
      "name": "ShipWizmo Migration Kit",
      "version": "5.0.0"
    }
  },
  "parameters": {
    "siteName": {
      "type": "string",
      "defaultValue": "broadreach-command-center",
      "metadata": {
        "description": "Name for the Static Web App (dashboard)"
      }
    },
    "apiAppName": {
      "type": "string",
      "defaultValue": "broadreach-command-center-api",
      "metadata": {
        "description": "Name for the API proxy App Service"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region"
      }
    },
    "sku": {
      "type": "string",
      "defaultValue": "B1",
      "allowedValues": [
        "B1",
        "B2",
        "S1"
      ],
      "metadata": {
        "description": "App Service Plan tier for API proxy"
      }
    },
    "hubspotPat": {
      "type": "secureString",
      "metadata": {
        "description": "HubSpot Private App Token (Account: 6282372)"
      }
    },
    "googleClientId": {
      "type": "string",
      "defaultValue": "105648453442-gjnirc4fa4tmii07lt1lmd353serh4ng.apps.googleusercontent.com",
      "metadata": {
        "description": "Google OAuth Client ID"
      }
    },
    "corsOrigins": {
      "type": "string",
      "defaultValue": "*",
      "metadata": {
        "description": "Comma-separated list of allowed CORS origins. Set to your frontend domain in production."
      }
    }
  },
  "variables": {
    "apiPlanName": "[concat(parameters('apiAppName'), '-plan')]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2022-09-01",
      "name": "[parameters('siteName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Free",
        "tier": "Free"
      },
      "properties": {
        "buildProperties": {
          "appLocation": "/",
          "outputLocation": "",
          "skipGithubActionWorkflowGeneration": true
        }
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-09-01",
      "name": "[variables('apiPlanName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('sku')]"
      },
      "kind": "linux",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-09-01",
      "name": "[parameters('apiAppName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('apiPlanName'))]"
      ],
      "kind": "app,linux",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('apiPlanName'))]",
        "siteConfig": {
          "linuxFxVersion": "PYTHON|3.11",
          "appCommandLine": "uvicorn api_server:app --host 0.0.0.0 --port 8000",
          "appSettings": [
            {
              "name": "HUBSPOT_PAT",
              "value": "[parameters('hubspotPat')]"
            },
            {
              "name": "GOOGLE_CLIENT_ID",
              "value": "[parameters('googleClientId')]"
            },
            {
              "name": "SCM_DO_BUILD_DURING_DEPLOYMENT",
              "value": "true"
            },
            {
              "name": "CORS_ORIGINS",
              "value": "[parameters('corsOrigins')]"
            }
          ]
        }
      }
    }
  ],
  "outputs": {
    "dashboardUrl": {
      "type": "string",
      "value": "[reference(parameters('siteName')).defaultHostname]"
    },
    "apiUrl": {
      "type": "string",
      "value": "[concat('https://', reference(parameters('apiAppName')).defaultHostName)]"
    }
  }
}