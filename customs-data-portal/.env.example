# Broad Reach Customs Data Portal — Environment Variables
# Copy this file to .env and fill in real values
# Works with: Replit Secrets | Docker .env | Azure App Settings

# Google OAuth 2.0 (shared with Customer Portal — same project: buoyant-silicon-345213)
GOOGLE_CLIENT_ID=105648453442-gjnirc4fa4tmii07lt1lmd353serh4ng.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# CORS allowed origins (comma-separated)
# Add your production domain when migrating off Perplexity hosting
CORS_ORIGINS=https://www.perplexity.ai,https://sites.pplx.app

# JWT session secret (auto-generated if not set — set explicitly in production for session persistence across restarts)
# JWT_SECRET=your-random-hex-secret-here

# Database path (SQLite for dev; replace with Azure SQL in production)
DATABASE_PATH=./customs.db
# DATABASE_URL=postgresql://user:pass@your-azure-sql.database.windows.net:5432/customs

# Optional: Anthropic API key for AI-powered CUSMA certificate generation
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server config
PORT=8000
HOST=0.0.0.0
