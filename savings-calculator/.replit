# Broad Reach Savings Calculator
# Static site + Python CGI backend (cgi-bin/quote.py handles quote form submissions)
run = "python -m http.server 8000 --cgi"
entrypoint = "index.html"
language = "python3"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "python -m http.server 8000 --cgi"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 8000
externalPort = 80
