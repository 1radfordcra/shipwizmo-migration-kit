{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Broad Reach Savings Calculator \u2014 Static Web App with optional CGI backend",
    "_generator": {
      "name": "ShipWizmo Migration Kit",
      "version": "5.0.0"
    }
  },
  "parameters": {
    "siteName": {
      "type": "string",
      "defaultValue": "broadreach-savings-calc",
      "metadata": {
        "description": "Name for the Static Web App"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region"
      }
    },
    "sku": {
      "type": "string",
      "defaultValue": "Free",
      "allowedValues": [
        "Free",
        "Standard"
      ],
      "metadata": {
        "description": "Static Web App pricing tier"
      }
    },
    "repositoryUrl": {
      "type": "string",
      "defaultValue": "https://github.com/shipwizmo/savings-calculator",
      "metadata": {
        "description": "GitHub repository URL"
      }
    },
    "branch": {
      "type": "string",
      "defaultValue": "main",
      "metadata": {
        "description": "Branch to deploy from"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2022-09-01",
      "name": "[parameters('siteName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('sku')]",
        "tier": "[parameters('sku')]"
      },
      "properties": {
        "repositoryUrl": "[parameters('repositoryUrl')]",
        "branch": "[parameters('branch')]",
        "buildProperties": {
          "appLocation": "/",
          "outputLocation": "",
          "skipGithubActionWorkflowGeneration": true
        }
      }
    }
  ],
  "outputs": {
    "siteUrl": {
      "type": "string",
      "value": "[reference(parameters('siteName')).defaultHostname]"
    }
  }
}