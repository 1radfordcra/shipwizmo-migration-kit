# Shipping Savings Calculator — Environment Variables
# Copy this file to .env and fill in real values
# Works with: Replit Secrets | Docker .env | Azure App Settings

# HubSpot (same token shared with Command Center and Outbound Machine — Account: 6282372)
# Used by cgi-bin/quote.py to create contacts/deals when users submit a quote request
HUBSPOT_PAT=pat-na1-your-hubspot-private-app-token

# Server config (for standalone/FastAPI mode)
PORT=8000
HOST=0.0.0.0
