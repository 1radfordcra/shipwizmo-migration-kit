# Broad Reach Outbound Machine — Environment Variables
# Copy this file to .env and fill in real values
# Works with: Replit Secrets | Docker .env | Azure App Settings

# HubSpot (Account: 6282372)
HUBSPOT_PAT=pat-na1-your-hubspot-private-app-token

# Apollo.io (Contact enrichment)
APOLLO_API_KEY=your-apollo-api-key

# Slack (Bot token for notifications)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Notion (Integration token for dashboard updates + exclusion list sync)
NOTION_TOKEN=secret_your-notion-integration-token
NOTION_CLIENTS_DATABASE_ID=your-notion-database-id-for-active-clients

# Zapier (Expandi → Slack routing webhook)
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/1360401/u0giijd/

# Expandi reversed webhook URLs (for auto-feeding prospects into LinkedIn campaigns)
# Domain is api.liaufa.com (NOT api.expandi.io)
EXPANDI_CAMPAIGN_A_WEBHOOK=https://api.liaufa.com/api/v1/open-api/campaign-instance/770808/assign/?key=YOUR_KEY&secret=YOUR_SECRET
EXPANDI_CAMPAIGN_B_WEBHOOK=https://api.liaufa.com/api/v1/open-api/campaign-instance/770814/assign/?key=YOUR_KEY&secret=YOUR_SECRET

# Expandi API credentials (used in reversed webhook URLs above)
EXPANDI_API_KEY=your-expandi-api-key
EXPANDI_API_SECRET=your-expandi-api-secret

# Email sending (for invitation emails)
GMAIL_SENDER=craig@brdrch.com

# SMTP (for safety guard alert emails — sends when exclusion list is compromised)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=craig@brdrch.com
SMTP_PASSWORD=your-gmail-app-password
ALERT_TO_EMAIL=craig@brdrch.com

# Notion dashboard (daily cron Step 7 — push run stats to Notion page)
NOTION_DASHBOARD_PAGE_ID=your-notion-page-id-for-outbound-dashboard

# Slack reporting (weekly report + hot lead alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#outbound-alerts

# HubSpot sender user ID (for sequence enrollment CLI tool)
HUBSPOT_SENDER_USER_ID=your-hubspot-user-id

# Dry-run mode (set to 1 to preview actions without making API calls)
# DRY_RUN=1

# CAN-SPAM compliance (must match physical_address.txt)
PHYSICAL_ADDRESS="Broad Reach Digital (a division of Asendia USA), 701 Ashland Ave, Folcroft, PA 19032"
